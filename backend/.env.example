# ─── Welcome to Russia · backend · environment ────────────────────────
# Copy to `.env` and fill in. Never commit the real `.env`.

# Bind address for the Axum server.
BIND_ADDR=0.0.0.0:3000

# ─── SurrealDB ────────────────────────────────────────────────────────
# A SurrealDB server must be reachable at SURREAL_URL.
# Start one locally with:
#   surreal start --user root --pass root memory
SURREAL_URL=http://localhost:8000
SURREAL_USER=root
SURREAL_PASS=root
SURREAL_NS=rshb
SURREAL_DB=svoe_rodnoe

# ─── Yandex Cloud (optional — falls back to mocks if absent) ──────────
# OAuth token for IAM exchange (long-lived, get from yandex.cloud).
# Used for AI Studio (foundationModels), Vision OCR, Translate.
YANDEX_OAUTH_TOKEN=

# Folder ID required for AI Studio, Translate, OCR.
YANDEX_FOLDER_ID=

# Speechkit accepts an Api-Key directly (simpler than IAM). Optional.
# If absent, Speechkit calls will fall back to the IAM token above.
YANDEX_API_KEY=

# Yandex GPT model URI. Override to use yandexgpt vs yandexgpt-lite.
YANDEX_GPT_MODEL=yandexgpt-lite/latest

# ─── Telegram (optional) ──────────────────────────────────────────────
# Bot token for proactive expiry alerts. Worker logs to stdout if absent.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Logging ──────────────────────────────────────────────────────────
RUST_LOG=info,welcome_to_russia=debug,tower_http=debug
